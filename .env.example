# -----------------------------------------------------------------------------
# Ryezenn Motion - Environment Variables Template
# -----------------------------------------------------------------------------
# Copy this file to a new file named '.env' and fill in the values below.
# Make sure to set these variables in your deployment platform (e.g., Render, VPS, Vercel, Cloud Run).

# Port on which the Express server runs (automatically assigned on most cloud hosts)
PORT=5000

# MongoDB Connection String (Atlas URI or Local URI)
MONGODB_URI=mongodb+srv://your_username:your_password@cluster.mongodb.net/your_db_name?retryWrites=true&w=majority

# Mustika Payment API Key (for QRIS payments)
MUSTIKA_API_KEY=your_mustika_payment_api_key

# Passcode/Key used to access the Admin Panel
ADMIN_KEY=your_admin_secret_passcode

# JWT Secret for securing customer sessions (should be a long random string)
JWT_SECRET=your_jwt_secret_random_key_here
